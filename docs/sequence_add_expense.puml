@startuml sequence_add_expense

skinparam defaultFontSize 13
skinparam sequenceMessageAlign center
skinparam sequenceArrowThickness 1.5
skinparam lifelineBorderColor #444444
skinparam sequenceParticipantBorderThickness 1.5
skinparam shadowing false
skinparam roundCorner 8

skinparam sequence {
    LifeLineBackgroundColor #FAFAFA
    ParticipantBackgroundColor #FFF8E1
    ParticipantBorderColor #F57F17
    ActorBackgroundColor #FFF3E0
    ActorBorderColor #E65100
}

autonumber "<b>[00]</b>"

title <b>Luồng Thêm Chi Tiêu (Phần 1/2) — Validate</b>\n<size:11>Thu thập input + Kiểm tra hạn mức</size>

actor       "User"           as U
participant "Menu"           as M
participant "InputValidator" as IV
participant "Budget"         as BDG

== Thu thập thông tin ==

U  -> M : chọn [3] Thêm chi tiêu
activate M

M -> IV : readDouble("So tien")
activate IV
IV --> M : amount
deactivate IV

M -> M  : pickCategory(wallet)
note right of M : Liệt kê danh mục đã có\n+ tuỳ chọn nhập mới

M -> IV : readString("Mo ta")
activate IV
IV --> M : title
deactivate IV

M -> IV : readString("Ghi chu")
activate IV
IV --> M : note
deactivate IV

== Kiểm tra hạn mức ngân sách ==

M -> BDG : getCategory(category)
activate BDG

alt category CÓ hạn mức

    BDG --> M : CategoryBudget cb
    M -> M   : ratio = (spent + amount) / limit

    alt ratio >= 1.0
        M --> U : "[!!] VƯỢT HẠN MỨC"
        M -> IV : confirm()
        activate IV
        IV --> M : proceed
        deactivate IV

    else ratio >= 0.8
        M --> U : "[!] CẢNH BÁO 80%+"
        M -> IV : confirm()
        activate IV
        IV --> M : proceed
        deactivate IV

    else ratio < 0.8
        M -> M : proceed = true
    end

    opt proceed == false
        M --> U : huỷ, quay lại menu
        return
    end

else CHƯA có hạn mức

    BDG --> M : <<throws>>\nInvalidInputException
    M -> M : catch → bỏ qua
    M -> M : proceed = true

end
deactivate BDG

note over M, BDG #LightBlue
  Validate xong → chuyển sang xử lý ghi giao dịch
  (xem sequence_add_expense_process.puml)
end note

deactivate M

@enduml