@startuml sequence_add_expense

skinparam defaultFontSize 13
skinparam sequenceMessageAlign center
skinparam sequenceArrowThickness 1.5
skinparam lifelineBorderColor #444444
skinparam sequenceParticipantBorderThickness 1.5
skinparam shadowing false
skinparam roundCorner 8

skinparam sequence {
    LifeLineBackgroundColor #FAFAFA
    ParticipantBackgroundColor #FFF8E1
    ParticipantBorderColor #F57F17
    ActorBackgroundColor #FFF3E0
    ActorBorderColor #E65100
}

autonumber "<b>[00]</b>"

title <b>Luồng Thêm Chi Tiêu (Phần 1/2) — Validate</b>\n<size:11>Thu thập input + Kiểm tra hạn mức</size>

actor       "User"           as U
participant "Menu"           as M
participant "InputValidator" as IV
participant "Budget"         as BDG

|||
== Thu thập thông tin ==
|||

U  -> M : chọn [3] Thêm chi tiêu
activate M

M -> IV : readDouble("So tien")
activate IV
IV --> M : amount
deactivate IV

M -> IV : readDetails(category, title, note)
activate IV
IV --> M : details
deactivate IV

|||
== Kiểm tra hạn mức ngân sách ==
|||

M -> BDG : getCategory(category)
activate BDG
BDG --> M : CategoryBudget cb
deactivate BDG

note right of M
  Nếu category chưa có hạn mức
  → bỏ qua kiểm tra, proceed = true
end note

alt ratio >= 0.8 (cảnh báo / vượt mức)

    M --> U : "[!] Cảnh báo hạn mức"
    M -> IV : confirm()
    activate IV
    IV --> M : proceed
    deactivate IV

else ratio < 0.8

    M -> M : proceed = true

end

opt proceed == false
    M --> U : huỷ, quay lại menu
end

note over M, BDG #LightBlue
  Validate xong → xem sequence_add_expense_process.puml
end note

deactivate M

@enduml
