' ╔═══════════════════════════════════════════════════════╗
' ║  PACKAGE: core                                        ║
' ║  Lớp cơ sở trừu tượng + toàn bộ exception hierarchy  ║
' ╚═══════════════════════════════════════════════════════╝
package "core" #D6EAF8 {

    abstract class Record {
        ' Lớp abstract gốc — không thể khởi tạo trực tiếp
        # id    : int
        # date  : string
        # title : string
        --
        # Record()
        + Record(id : int, date : string, title : string)
        + {abstract} displayInfo() : void
        + getId()    : int
        + getDate()  : string
        + getTitle() : string
        + setDate(d  : string) : void
        + setTitle(t : string) : void
        + operator==(other : Record) : bool
        + operator<<(os : ostream, r : Record) : ostream&
    }

    class OPEPException {
        ' Base của toàn bộ exception trong ứng dụng
        # message : string
        --
        + OPEPException(msg : string)
        + what() : const char*
    }

    class InvalidInputException {
        ' Input sai định dạng, ngoài khoảng, hoặc rỗng
        --
        + InvalidInputException(msg : string)
    }
    class FileNotFoundException {
        ' Không tìm thấy file cần đọc / ghi
        --
        + FileNotFoundException(filename : string)
    }
    class AuthenticationException {
        ' Sai mật khẩu hoặc tài khoản không tồn tại
        --
        + AuthenticationException(msg : string)
    }
    class InsufficientBalanceException {
        ' Chi vượt số dư hiện có trong Wallet
        --
        + InsufficientBalanceException(required : double, available : double)
    }
    class BudgetExceededException {
        ' Chi vượt hạn mức ngân sách danh mục
        --
        + BudgetExceededException(category : string, limit : double, spent : double)
    }
}

' ╔═══════════════════════════════════════════════════════╗
' ║  PACKAGE: task                                        ║
' ║  Quản lý công việc (Task)                             ║
' ╚═══════════════════════════════════════════════════════╝
package "task" #D5F5E3 {

    enum Priority {
        LOW    = 0
        MEDIUM = 1
        HIGH   = 2
    }

    class Task {
        ' Lớp con cụ thể của Record — một công việc cần làm
        - completed : bool
        - priority  : Priority
        - deadline  : string
        --
        + Task()
        + Task(id : int, date : string, title : string,\n      priority : Priority, deadline : string)
        + isCompleted() : bool
        + getPriority() : Priority
        + getDeadline() : string
        + setCompleted(v : bool)    : void
        + setPriority(p : Priority) : void
        + setDeadline(d : string)   : void
        + displayInfo() : void
        + operator==(other : Task) : bool
        + operator!=(other : Task) : bool
        + operator<<(os : ostream, t : Task) : ostream&
        + operator>>(is : istream, t : Task) : istream&
    }

    class TaskManager {
        ' Quản lý tập hợp Task qua unique_ptr — sở hữu độc quyền
        - tasks : vector<unique_ptr<Task>>
        --
        + TaskManager()
        + addTask(task : unique_ptr<Task>) : void
        + removeTask(id : int) : void
        + markDone(id : int)   : void
        + sortByPriority()     : void
        + getById(id : int)    : const Task*
        + getAll()             : const vector<unique_ptr<Task>>&
        + count()              : size_t
        + countCompleted()     : size_t
        + displayAll()         : void
    }
}

' ╔═══════════════════════════════════════════════════════╗
' ║  PACKAGE: money                                       ║
' ║  Giao dịch tài chính, ví tiền, ngân sách             ║
' ╚═══════════════════════════════════════════════════════╝
package "money" #FEF9E7 {

    enum TransactionType {
        INCOME  = 0
        EXPENSE = 1
    }

    class Transaction {
        ' Lớp con cụ thể của Record — một giao dịch thu/chi
        - amount   : double
        - type     : TransactionType
        - category : string
        - note     : string
        --
        + Transaction()
        + Transaction(id : int, date : string, title : string,\n             amount : double, type : TransactionType,\n             category : string, note : string)
        + getAmount()   : double
        + getType()     : TransactionType
        + getCategory() : string
        + getNote()     : string
        + setAmount(a   : double) : void
        + setCategory(c : string) : void
        + setNote(n     : string) : void
        + displayInfo() : void
        + operator==(other : Transaction) : bool
        + operator!=(other : Transaction) : bool
        + operator<<(os : ostream, t : Transaction) : ostream&
        + operator>>(is : istream, t : Transaction) : istream&
    }

    class Wallet {
        ' Quản lý số dư và danh sách giao dịch
        ' balance là PRIVATE — chỉ thay đổi qua addIncome/addExpense
        - balance       : double
        - transactions  : vector<shared_ptr<Transaction>>
        - nextId        : int
        - ownerUsername : string
        --
        + Wallet(ownerUsername : string, initialBalance : double)
        + getBalance()         : double
        + getOwnerUsername()   : string
        + getTransactions()    : const vector<shared_ptr<Transaction>>&
        + addIncome(amount : double, category : string,\n          title : string, date : string, note : string)\n          : shared_ptr<Transaction>
        + addExpense(amount : double, category : string,\n           title : string, date : string, note : string)\n           : shared_ptr<Transaction>
        + loadTransaction(t : Transaction) : void
        + totalIncome()    : double
        + totalExpense()   : double
        + displaySummary() : void
        + operator<<(os : ostream, w : Wallet) : ostream&
    }

    class CategoryBudget <<struct>> {
        ' Hạn mức và chi tiêu thực tế của một danh mục
        + category : string
        + limit    : double
        + spent    : double
        --
        + CategoryBudget(cat : string, lim : double)
        + usageRatio() : double
        + remaining()  : double
        + isExceeded() : bool
        + isNearLimit() : bool
    }

    class Budget {
        ' Quản lý hạn mức ngân sách theo danh mục trong một tháng
        - month      : string
        - categories : map<string, CategoryBudget>
        --
        + Budget(month : string)
        + setLimit(category : string, limit : double)     : void
        + recordExpense(category : string, amount : double) : bool
        + syncFromTransactions(\n    txns : vector<shared_ptr<Transaction>>) : void
        + getCategory(category : string) : const CategoryBudget&
        + totalLimit()  : double
        + totalSpent()  : double
        + getMonth()    : string
        + displayBudget() : void
        + saveLimits(filename : string) : void
        + loadLimits(filename : string) : void
        + operator<<(os : ostream, b : Budget) : ostream&
    }
}

' ╔═══════════════════════════════════════════════════════╗
' ║  PACKAGE: data                                        ║
' ║  Người dùng, xác thực, lưu trữ, mã hóa              ║
' ╚═══════════════════════════════════════════════════════╝
package "data" #FDEDEC {

    class User {
        ' Tài khoản người dùng — password được hash một chiều
        - username     : string
        - passwordHash : string
        - createdDate  : string
        --
        + User()
        + User(username : string, passwordHash : string, createdDate : string)
        + getUsername()     : string
        + getPasswordHash() : string
        + getCreatedDate()  : string
        + setPasswordHash(hash : string) : void
        + operator==(other : User) : bool
        + operator<<(os : ostream, u : User) : ostream&
        + operator>>(is : istream, u : User) : istream&
    }

    class "Database<T>" as DatabaseT <<template>> {
        ' Template class lưu/nạp vector<T> ra file có mã hóa XOR
        ' Yêu cầu T: default ctor + operator<< + operator>>
        - filename  : string
        - encrypted : bool
        - encKey    : string
        --
        + Database(filename : string, encrypted : bool, key : string)
        + exists()                      : bool
        + getFilename()                 : string
        + save(records : vector<T>)     : void
        + load()                        : vector<T>
        + append(record : T)            : void
        + clear()                       : void
    }

    class AuthManager {
        ' Đăng ký, đăng nhập, đổi mật khẩu — dùng Database<User> nội bộ
        - dataDir : string
        - userDb  : Database<User>
        --
        + AuthManager(dataDir : string)
        + registerUser(username : string, password : string) : shared_ptr<User>
        + login(username : string, password : string)        : shared_ptr<User>
        + changePassword(username : string,\n               oldPassword : string,\n               newPassword : string) : void
        + userExists(username : string)                      : bool
    }

    class Encryption <<utility>> {
        ' Tập hợp hàm tiện ích mã hóa — không có state, dùng như static
        --
        + {static} xorCipher(data : string, key : string)      : string
        + {static} hexEncode(data : string)                     : string
        + {static} hexDecode(hex : string)                      : string
        + {static} hashPassword(password : string)              : string
        + {static} encryptToFile(data : string, key : string)   : string
        + {static} decryptFromFile(encoded : string, key : string) : string
    }
}

