package "ui" #F4ECF7 {

    class MenuItem <<struct>> {
        ' Một mục menu: nhãn + hành động lambda
        + label       : string
        + action      : function<void()>
        + isSeparator : bool
    }

    class Menu {
        ' Menu console nhiều cấp — exception từ action được bắt tự động
        - title     : string
        - items     : vector<MenuItem>
        - running   : bool
        - backLabel : string
        --
        + Menu(title : string, backLabel : string)
        + addItem(label : string, action : function<void()>) : void
        + addSeparator() : void
        + run()  : void
        + stop() : void
    }

    class Dashboard {
        ' Hiển thị tổng quan ASCII: số dư, thu/chi tháng, task sắp đến hạn
        - wallet      : const Wallet&
        - taskManager : const TaskManager&
        - username    : string
        - today       : string
        --
        + Dashboard(wallet : Wallet, taskManager : TaskManager, username : string)
        + render() : void
        - getUpcomingTasks(days : int) : vector<const Task*>
        - getTodayExpense()  : double
        - getMonthIncome()   : double
        - getMonthExpense()  : double
    }

    class InputValidator <<utility>> {
        ' Validate và đọc input — re-prompt khi sai, throw khi stream lỗi
        --
        + {static} readInt(prompt : string, min : int, max : int)                    : int
        + {static} readDouble(prompt : string, min : double, max : double)           : double
        + {static} readString(prompt : string, minLen : int, maxLen : int)           : string
        + {static} readDate(prompt : string, allowEmpty : bool)                      : string
        + {static} readPassword(prompt : string, minLen : int)                       : string
        + {static} confirm(prompt : string)                                          : bool
        + {static} pause(msg : string)                                               : void
    }
}

' ═══════════════════════════════════════════════════════════
' QUAN HỆ
' Đặt sau tất cả package để PlantUML layout chính xác
' ═══════════════════════════════════════════════════════════

' ── Inheritance: Exception hierarchy ──────────────────────
' 5 lớp exception cụ thể kế thừa OPEPException
' OPEPException kế thừa std::exception (ngoài scope dự án)
InvalidInputException        --|> OPEPException
FileNotFoundException        --|> OPEPException
AuthenticationException      --|> OPEPException
InsufficientBalanceException --|> OPEPException
BudgetExceededException      --|> OPEPException

' ── Inheritance: Record hierarchy ─────────────────────────
' Kế thừa public — quan hệ IS-A
' Task::displayInfo() và Transaction::displayInfo() ghi đè pure virtual
Task        --|> Record
Transaction --|> Record

' ── Dependency: enum ──────────────────────────────────────
Task        ..> Priority        : uses
Transaction ..> TransactionType : uses

' ── Composition: TaskManager owns Task (unique_ptr) ───────
' Khi TaskManager bị destroy → tất cả Task bị delete tự động
' Copy bị xóa (= delete) vì unique_ptr không copyable
TaskManager "1" *-- "0..*" Task : owns (unique_ptr) >

' ── Composition: Wallet owns Transaction (shared_ptr) ─────
' Wallet tạo Transaction qua addIncome / addExpense
' shared_ptr cho phép caller cũng giữ reference tạm thời
Wallet "1" *-- "0..*" Transaction : owns (shared_ptr) >

' ── Composition: Budget chứa CategoryBudget trong map ─────
Budget "1" *-- "0..*" CategoryBudget : contains >

' ── Dependency: Budget cần Transaction để sync spending ───
Budget ..> Transaction : <<use>>\nsyncFromTransactions()

' ── Composition: AuthManager chứa Database<User> ──────────
' Database<User> là member trực tiếp (không phải pointer)
AuthManager "1" *-- "1" DatabaseT : userDb\n(Database<User>) >

' ── Dependency: Database<T> dùng Encryption ───────────────
DatabaseT ..> Encryption : <<use>>\nencrypt / decrypt

' ── Instantiation: Database<T> được dùng với 3 kiểu ───────
DatabaseT ..> User        : <<bind T=User>>
DatabaseT ..> Task        : <<bind T=Task>>
DatabaseT ..> Transaction : <<bind T=Transaction>>

' ── Composition: Menu chứa danh sách MenuItem ─────────────
Menu "1" *-- "0..*" MenuItem : contains >

' ── Aggregation: Dashboard tham chiếu (không sở hữu) ──────
' Dashboard nhận Wallet& và TaskManager& qua constructor
' Lifetime của Wallet/TaskManager do runSession() quản lý
Dashboard "1" o-- "1" Wallet      : observes (const&) >
Dashboard "1" o-- "1" TaskManager : observes (const&) >

@enduml
